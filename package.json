{
  "name": "celsius-inventory",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "cd apps/mobile && npx expo start",
    "dev:api": "cd packages/api && npm run dev",
    "db:generate": "cd packages/db && npx prisma generate",
    "db:push": "cd packages/db && npx prisma db push",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:seed": "cd packages/db && npx tsx seed.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
